# SPSS-Mac-MCP Configuration
# Copy this file to .env and fill in values as needed

# ─── SPSS installation ────────────────────────────────────────────────
# Path to IBM SPSS Statistics installation directory
# Auto-detected on macOS (/Applications/IBM SPSS Statistics XX/) and Windows
# SPSS_INSTALL_PATH=/Applications/IBM SPSS Statistics 27/SPSS Statistics.app/Contents/MacOS

# ─── PROCESS macro (optional) ─────────────────────────────────────────
# Path to Andrew Hayes' PROCESS macro process.sps file.
# Download from https://www.processmacro.org
# Auto-detected from ~/Downloads, ~/Documents, ~/Desktop if not set.
# PROCESS_MACRO_PATH=/Users/yourname/Downloads/PROCESS v4.1/PROCESS v4.1 for SPSS/process.sps

# ─── Directories ───────────────────────────────────────────────────────
# Temporary intermediate files (runner .py and OMS text output)
# SPSS_TEMP_DIR=/tmp/spss-mcp

# Persistent SPSS outputs (.spv viewer files and executed .sps syntax files)
# SPSS_RESULTS_DIR=/tmp/spss-mcp/results

# ─── Timeouts ──────────────────────────────────────────────────────────
# Maximum seconds to wait for an SPSS analysis to complete
# SPSS_TIMEOUT=120

# Maximum seconds to wait for SPSS engine to start (cold start can take 30-60s)
# SPSS_STARTUP_TIMEOUT=300

# ─── Force file-only mode ──────────────────────────────────────────────
# Set to 1 to disable real SPSS engine even if installed
# SPSS_NO_SPSS=0
