# SPSS MCP Server Configuration
# Copy this file to .env and fill in values as needed

# Path to IBM SPSS Statistics installation directory
# If not set, the server will try to auto-detect via Windows registry and common paths
# SPSS_INSTALL_PATH=C:\Program Files\IBM\SPSS Statistics\31

# Directory for temporary intermediate files (runner .py and OMS text output)
# Defaults to %TEMP%\spss-mcp
# SPSS_TEMP_DIR=%TEMP%\spss-mcp

# Directory for persistent SPSS outputs (.spv viewer files and executed .sps syntax files)
# Defaults to %TEMP%\spss-mcp\results
# SPSS_RESULTS_DIR=%TEMP%\spss-mcp\results

# Maximum seconds to wait for an SPSS batch job to complete
# SPSS_TIMEOUT=120

# Set to 1 to force pyreadstat-only mode even if SPSS is installed
# SPSS_NO_SPSS=0
